{
	"name": "svelte-locale",
	"version": "0.0.8",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && mkdir -p bin && cp src/lib/i18n/bin/init.js bin/init.js && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"bin": {
		"svelte-locale": "bin/init.js"
	},
	"files": [
		"dist",
		"bin",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./svelte": {
			"types": "./dist/i18n/svelte/index.d.ts",
			"svelte": "./dist/i18n/svelte/index.js",
			"default": "./dist/i18n/svelte/index.js"
		},
		"./server": {
			"types": "./dist/i18n/server.d.ts",
			"default": "./dist/i18n/server.js"
		},
		"./vite": {
			"types": "./dist/i18n/vite/index.d.ts",
			"default": "./dist/i18n/vite/index.js"
		}
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"@sveltejs/kit": {
			"optional": true
		}
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^22",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/VincentBarkman/svelte-locale.git"
	},
	"homepage": "https://github.com/VincentBarkman/svelte-locale#readme",
	"bugs": {
		"url": "https://github.com/VincentBarkman/svelte-locale/issues"
	},
	"keywords": [
		"svelte"
	]
}
